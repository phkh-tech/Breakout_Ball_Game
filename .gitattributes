# Handle line endings automatically for files detected as text 
# and truly leave binary files alone.
* text=auto

# Force standard LF for all shell scripts so they run on Linux/WSL
*.sh text eol=lf

# Ensure Windows batch files keep their carriage returns
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary